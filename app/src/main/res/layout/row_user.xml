<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1D6DA"
    android:backgroundTint="#FFF7F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Avatar Circle -->
        <TextView
            android:id="@+id/txtUserAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="A"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_user_avatar"/>

        <!-- User Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">

            <!-- Name -->
            <TextView
                android:id="@+id/txtUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="#4A2C2A"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <!-- Email -->
            <TextView
                android:id="@+id/txtUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@gmail.com"
                android:textColor="#7A6A6A"
                android:textSize="13sp"
                android:layout_marginTop="3dp"/>

            <!-- Password (Masked) -->
            <TextView
                android:id="@+id/txtUserPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password: ••••••••"
                android:textColor="#B09A9A"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Optional indicator -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/bg_icon_yellow"
            android:tint="#E6A4B4"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>