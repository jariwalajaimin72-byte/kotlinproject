<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightPinkBg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <!-- LOGO -->
        <androidx.cardview.widget.CardView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="70dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@android:color/white">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@mipmap/logo"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>

        <!-- REGISTER CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Let's get you started!"
                    android:textSize="20sp"
                    android:textColor="@color/deeperPink"
                    android:layout_gravity="center_horizontal"
                    android:paddingBottom="16dp"/>

                <!-- NAME -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FDF5F0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:background="@color/lightPinkBg"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="10dp"
                            android:src="@mipmap/user"
                            android:tint="@color/deeperPink"/>

                        <EditText
                            android:id="@+id/etname"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Enter your full name"
                            android:inputType="textPersonName"
                            android:textColor="#4B3B2D"
                            android:textSize="15sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- EMAIL -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FDF5F0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:background="@color/lightPinkBg"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="10dp"
                            android:src="@mipmap/email"
                            android:tint="@color/deeperPink"/>

                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Enter your email"
                            android:inputType="textEmailAddress"
                            android:textColor="#4B3B2D"
                            android:textSize="15sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- PASSWORD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FDF5F0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/lightPinkBg"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="10dp"
                            android:src="@mipmap/pass"
                            android:tint="@color/deeperPink"/>

                        <EditText
                            android:id="@+id/etpassword"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Enter password"
                            android:inputType="textPassword"
                            android:textColor="#4B3B2D"
                            android:textSize="15sp"/>

                        <ImageView
                            android:id="@+id/eyeIconPass"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/ic_eye_closed"
                            android:tint="@color/deeperPink"
                            android:clickable="true"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CONFIRM PASSWORD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FDF5F0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/lightPinkBg"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="10dp"
                            android:src="@mipmap/cpass"
                            android:tint="@color/deeperPink"/>

                        <EditText
                            android:id="@+id/etconpass"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Confirm password"
                            android:inputType="textPassword"
                            android:textColor="#4B3B2D"
                            android:textSize="15sp"/>

                        <ImageView
                            android:id="@+id/eyeIconConPass"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/ic_eye_closed"
                            android:tint="@color/deeperPink"
                            android:clickable="true"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- REGISTER BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/login_button"
                    android:backgroundTint="@null"
                    android:elevation="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:stateListAnimator="@null"
                    android:text="REGISTER NOW "
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:cornerRadius="28dp"
                    app:rippleColor="#80FFFFFF" />

                <TextView
                    android:id="@+id/tvLoginNow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? Login"
                    android:textColor="@color/deeperPink"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>