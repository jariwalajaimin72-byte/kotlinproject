<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightPinkBg"
    android:padding="20dp"
    tools:context=".activity.AdminAddCategoryActivity">

    ```
    <!-- TOP SPACE (pushes content downward) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Title -->
    <TextView
        android:id="@+id/textViewHeading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Update Category"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/warmBrown"
        android:gravity="center"
        android:layout_marginBottom="18dp"/>

    <!-- Soft Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/creamCard"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/catImg"
                android:layout_width="115dp"
                android:layout_height="115dp"
                android:src="@mipmap/logo_one"
                app:civ_border_width="3dp"
                app:civ_border_color="@color/deepRose"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btnChoose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Image"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/softPink"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"/>

            <EditText
                android:id="@+id/editTextCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter category name"
                android:textColor="@color/warmBrown"
                android:textColorHint="@color/softPink"
                android:layout_marginTop="18dp"
                android:background="@drawable/product_image_bg"
                android:padding="14dp"
                android:inputType="text"/>

            <Button
                android:id="@+id/buttonUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update Category"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/deeperPink"
                android:padding="14dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- BOTTOM SPACE (pushes content upward) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    ```

</LinearLayout>
