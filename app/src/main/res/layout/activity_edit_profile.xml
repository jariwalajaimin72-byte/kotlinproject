<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightPinkBg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header with curved bottom -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:background="@color/creamNude"
            android:elevation="4dp">

            <ImageView
                 android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:src="@mipmap/leftsidearrow"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Edit Profile"
                android:textColor="@color/dark_brown"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- Profile Picture (overlaps header) -->

        <!-- Form Fields -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="172dp"
            android:layout_marginTop="-50dp"
            android:gravity="center"
            android:orientation="vertical">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgProfile"
                android:layout_width="100dp"
                android:layout_height="110dp"
                android:layout_marginTop="35dp"
                android:src="@mipmap/logo_one"
                app:civ_border_color="@color/deeperPink"
                app:civ_border_width="3dp" />

            <!--            <TextView-->
            <!--                android:id="@+id/tvChangePicture"-->
            <!--                android:layout_width="wrap_content"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:text="Change Picture"-->
            <!--                android:textColor="@color/deeperPink"-->
            <!--                android:textStyle="bold"-->
            <!--                android:layout_marginTop="8dp"/>-->
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="339dp"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_cream"
                android:hint="Username"
                android:padding="12dp"
                android:textColor="@color/dark_brown"
                android:textColorHint="@color/dark_brown" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_cream"
                android:hint="Email Id"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:textColor="@color/dark_brown"
                android:textColorHint="@color/dark_brown" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_cream"
                android:hint="Phone Number"
                android:inputType="phone"
                android:padding="12dp"
                android:textColor="@color/dark_brown"
                android:textColorHint="@color/dark_brown" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_cream"
                android:hint="Password"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="@color/dark_brown"
                android:textColorHint="@color/dark_brown" />

            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/rosePink"
                android:clipToOutline="true"
                android:elevation="4dp"
                android:text="Update"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>