<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F8"
    tools:context=".util.MainActivity">

    <!-- Top Greeting -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Welcome, Kripa!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4B3B2D"
        android:fontFamily="sans-serif-medium"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Featured Products Carousel -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFeatured"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Quick Action Buttons (Orders & Favorites) -->
    <LinearLayout
        android:id="@+id/llQuickActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/rvFeatured"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnOrders"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="My Orders"
            android:backgroundTint="#F28CA0"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginEnd="4dp"
            android:fontFamily="sans-serif-medium"/>

        <Button
            android:id="@+id/btnFavorites"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Favorites"
            android:backgroundTint="#F28CA0"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginStart="4dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- Recommended Products Section -->
    <TextView
        android:id="@+id/tvRecommended"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recommended for You"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#4B3B2D"
        android:layout_marginTop="20dp"
        android:paddingStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/llQuickActions"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Recommended Products RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRecommended"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvRecommended"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>