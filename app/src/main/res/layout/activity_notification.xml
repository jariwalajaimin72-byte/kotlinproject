<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/lightPinkBg"
    tools:context=".activity.NotificationActivity">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/etback"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@mipmap/leftsidearrow"
            android:contentDescription="Back"
        android:tint="@color/deeperPink"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notifications"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/dark_brown"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <!-- Empty State Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="22dp"
        android:orientation="vertical">

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_empty_card"
            android:padding="28dp"
            android:gravity="center">

            <!-- Icon -->
            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_empty_notification"
                app:tint="@color/deeperPink"
                android:alpha="0.9"/>

            <!-- Title -->
            <TextView
                android:id="@+id/tvNoNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Notifications Yet"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="@color/dark_brown"
                android:layout_marginBottom="6dp"
                android:gravity="center"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We’ll notify you about order updates, offers and delivery status here 🧶"
                android:textColor="#9A8578"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>