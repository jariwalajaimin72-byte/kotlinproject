<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/creamCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center">
        <!-- Product Image -->
        <ImageView
            android:id="@+id/imgCartProduct"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            android:padding="8dp"
            android:elevation="2dp" />

        <!-- Product Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name -->
            <TextView
                android:id="@+id/tvCartName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crochet Flower Bouquet"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/warmBrown"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Price -->
            <TextView
                android:id="@+id/tvCartPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 499"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/deeperPink"
                android:layout_marginTop="4dp" />

            <!-- Quantity Controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="-"
                    android:textSize="18sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:textColor="@android:color/white"
                    app:cornerRadius="18dp"
                    android:backgroundTint="@color/softPink" />

                <TextView
                    android:id="@+id/tvQty"
                    android:layout_width="40dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/warmBrown"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/product_image_bg" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="+"
                    android:textSize="18sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:textColor="@android:color/white"
                    app:cornerRadius="18dp"
                    android:backgroundTint="@color/softPink" />
            </LinearLayout>

            <!-- Remove button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveCart"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Remove"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:textColor="@color/deeperPink"
                android:backgroundTint="@android:color/transparent"
                app:strokeColor="@color/deeperPink"
                app:strokeWidth="1dp"
                app:cornerRadius="18dp"
                app:rippleColor="@color/softPink" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>