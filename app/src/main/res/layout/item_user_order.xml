<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="8dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/creamCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Image Plate -->


        <!-- Space -->
        <Space
            android:layout_width="14dp"
            android:layout_height="wrap_content"/>

        <!-- Right Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Product Name -->
            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crochet Tulip Flower Bouquet"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/warmBrown"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- Ordered By -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ordered by: Customer Name"
                android:textSize="13sp"
                android:textColor="@color/warmBrown"
                android:alpha="0.7"
                android:layout_marginTop="4dp"/>

            <!-- Price -->
            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 899"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/deeperPink"
                android:layout_marginTop="6dp"/>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_status_soft"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>