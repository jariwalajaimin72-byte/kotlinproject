<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">

    ```
    <!-- pressed state -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#E57399"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- default state -->
    <item>
        <shape>
            <solid android:color="#F48FB1"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    ```

</selector>
